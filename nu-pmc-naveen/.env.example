# ── SERVER
NODE_ENV=production
PORT=3000
APP_URL=https://nuassociates.in

# ── DATABASE
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nu_pmc
DB_USER=nu_app
DB_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# ── SESSION
SESSION_SECRET=CHANGE_THIS_TO_RANDOM_64_CHARACTER_STRING

# ── FILE UPLOADS
UPLOAD_DIR=/var/www/nu-pmc-uploads
MAX_FILE_SIZE_MB=20

# ── TWILIO WHATSAPP
# Get all these from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WA_NUMBER=whatsapp:+14155238886

# ── WHATSAPP MESSAGE TEMPLATE SIDs
# Get these from Twilio console after Meta approves templates
TWILIO_TMPL_DRAWING_ISSUED=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TMPL_QUERY_RAISED=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TMPL_OTP=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TMPL_DAILY_REPORT=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── WEBHOOK VERIFY TOKEN (set same value in Twilio console)
WHATSAPP_VERIFY_TOKEN=nu-pmc-verify

# ── SECURITY
ALLOWED_ORIGINS=https://nuassociates.in,https://www.nuassociates.in

# ── FINANCE
PETTY_CASH_THRESHOLD=25000          # PMC Head replenishment limit. Above this needs principal.

# ── AI SERVICE
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514        # Routine tasks — photo tagging, HSN, weekly narrative
AI_MODEL_HEAVY=claude-opus-4-20250514    # Complex tasks — drawing analysis, CN impact, schedule risk, lessons
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── EMAIL SERVICE
EMAIL_PROVIDER=ses
EMAIL_FROM=noreply@nuassociates.com
EMAIL_FROM_NAME=nu associates
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1

# ── PAYMENT BANK
PAYMENT_BANK=icici

# ── WHATSAPP PROVIDER
WA_PROVIDER=twilio

# ── ADDITIONAL TWILIO TEMPLATES
TWILIO_TMPL_DAILY_REPORT=your_template_sid
TWILIO_TMPL_PAYMENT_CONFIRMED=your_template_sid
TWILIO_TMPL_DEFECT_RAISED=your_template_sid
TWILIO_TMPL_PI_RAISED=your_template_sid
TWILIO_TMPL_USER_CREATED=your_template_sid

# ── ALTERNATIVE PROVIDERS (commented out — swap if needed)
# OPENAI_API_KEY=your_openai_key
# SENDGRID_API_KEY=your_sendgrid_key
# RESEND_API_KEY=your_resend_key
# GUPSHUP_NUMBER=your_gupshup_number
# GUPSHUP_API_KEY=your_gupshup_key

# ── LOOKUP SERVICES
OPENWEATHER_API_KEY=your_openweather_key
GOOGLE_PLACES_API_KEY=your_google_places_key

# ── VPS HEALTH & MONITORING
ALERT_PHONE=91XXXXXXXXXX            # Guru's WhatsApp number for VPS alerts
BACKUP_DIR=/home/backups/nu-pmc     # Local backup directory
S3_BUCKET=nu-pmc-backups            # AWS S3 bucket for offsite backup (optional)
APP_DOMAIN=nuassociates.in          # Domain for SSL cert monitoring

# ── APP CONFIG
APP_BASE_URL=https://nuassociates.in   # Used for WhatsApp deep-links
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886  # Full WhatsApp sender address

# ── GOVERNMENT APIS
GSTIN_API_KEY=your_gstin_api_key    # For GSTIN validation

# ── GURU / ADMIN
GURU_PHONE=91XXXXXXXXXX             # Guru's WhatsApp — receives VPS crash alerts
MYSQL_ROOT_PASSWORD=                # Used by setup.sh for DB creation

# ── SESSION
SESSION_SECRET=generate_with_openssl_rand_hex_32

# ── MISSING FROM EARLIER
DB_PASS=                            # Alias for DB_PASSWORD (some scripts use this)

# ── ICICI BULK PAYMENT
ICICI_DEBIT_ACCOUNT=233705000984    # nu associates LLP debit account number
NU_BANK_ACCOUNT=233705000984        # Alias

# ── Added v3 audit
# Unix socket for local MySQL (takes precedence over DB_HOST:DB_PORT if set)
# DB_SOCKET=/var/run/mysqld/mysqld.sock

# REQUIRED in production — UTR webhook refuses to process if unset (see routes/payments.js)
ICICI_WEBHOOK_SECRET=change-me-strong-random-string

# AI / LLM integrations (required if AI features enabled)
# OPENAI_API_KEY=
# GUPSHUP_API_KEY=
# GUPSHUP_NUMBER=

# Email providers — at least one required for email delivery
# RESEND_API_KEY=
# SENDGRID_API_KEY=

# REQUIRED if using AWS SES — webhook refuses without this
SES_WEBHOOK_SECRET=change-me-strong-random-string

# ── Rate-limiter overrides (testing / dev only)
# Set to "1" to bypass the global API rate limiter (default 100 req/min/IP).
# DISABLE_API_RATE_LIMIT=
# Set to "1" to bypass the login rate limiter (default 10 attempts/15min/IP).
# DISABLE_LOGIN_RATE_LIMIT=

# ── MATRIX (v5.23+ substrate — rolls out per-project)
# When unset, services/matrix-adapter.js runs in DRY_RUN mode (sends are
# captured to matrix_outbox table for inspection but no HTTP is made).
# When set, sends go live. See handoff-2026-04-28/2_ForMe/nu-pmc-matrix-integration-brief-v2.docx §8.
#
# MATRIX_HOMESERVER=https://nuassociates.ems.host
# MATRIX_BOT_TOKEN=syt_xxxxxxxxxxxxxxxxx
# MATRIX_BOT_USER_ID=@nu_pmc_bot:nuassociates.ems.host
#
# Set to "1" to forcibly disable Matrix even if the above are configured.
# Used to fall back to whatsapp without un-setting credentials.
# MATRIX_DISABLED=

# ── NOTIFICATION CHANNEL (global default)
# Per-user notification_channel column in users table can override this.
# Values: matrix | whatsapp | both    Default: whatsapp
# NOTIFICATIONS=whatsapp
