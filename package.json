{
  "name": "nu-pmc",
  "version": "1.0.0",
  "description": "nu associates Site PMC Application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:modules": "jest --testPathPatterns='modules/.*/tests/' --forceExit --detectOpenHandles",
    "lint:boundaries": "node scripts/check-module-boundaries.js"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.19.0",
    "helmet": "^7.2.0",
    "jsqr": "^1.4.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.1",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.18.0",
    "sharp": "^0.33.5",
    "twilio": "^4.23.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "license-checker": "^25.0.1",
    "madge": "^8.0.0",
    "nodemon": "^3.1.0",
    "playwright": "^1.59.1",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 10000,
    "verbose": true,
    "setupFiles": [
      "./tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/modules/",
      "/tests/e2e/",
      "/tests/new-features.test.js"
    ]
  }
}
