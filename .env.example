# Server Configuration
PORT=5100
SESSION_SECRET=your_session_secret_here
FORCE_HTTPS=false
ALLOWED_ORIGINS=http://localhost:5100
DISABLE_API_RATE_LIMIT=false
DISABLE_LOGIN_RATE_LIMIT=false

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=nu_pmc
DB_SOCKET=

# URLs
PWA_BASE_URL=http://localhost:5100
APP_URL=http://localhost:5100
APP_BASE_URL=http://localhost:5100

# Notifications & Third-Party APIs
# NOTIFICATIONS=matrix (default) | whatsapp (emergency rollback only — see services/messaging.js P10.2)
# In dev: leave MATRIX_BOT_TOKEN empty → DRY_RUN mode (captures to matrix_outbox, no real sends)
# To fully silence Matrix: set MATRIX_DISABLED=1 (returns no-ops immediately)
NOTIFICATIONS=matrix
MATRIX_HOMESERVER=
MATRIX_BOT_TOKEN=
MATRIX_BOT_USER_ID=
MATRIX_DISABLED=

# AI Provider
AI_PROVIDER=anthropic
AI_MODEL=claude-3-5-sonnet-20241022
AI_MODEL_HEAVY=claude-3-opus-20240229
ANTHROPIC_API_KEY=

# Email Configurations
# EMAIL_PROVIDER=smtp  → etke.cc hosted email (recommended for production)
# EMAIL_PROVIDER=ses   → AWS SES (stub, not yet wired — see services/email.js)
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@nuassociates.in
EMAIL_FROM_NAME=nu associates
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# SMTP settings — used by both EMAIL_PROVIDER=smtp and the emergency-mail watchdog.
# For etke.cc hosted email: use the SMTP credentials from your etke.cc dashboard.
# Port 587 = STARTTLS (recommended), 465 = SSL/TLS
EMERGENCY_SMTP_HOST=mail.etke.cc
EMERGENCY_SMTP_PORT=587
EMERGENCY_SMTP_USER=
EMERGENCY_SMTP_PASS=
EMERGENCY_ALERT_TO=
EMERGENCY_ALERT_FROM=noreply@nuassociates.in

# Storage & Logging
LOG_DIR=./logs
UPLOAD_DIR=./uploads

# Other API Keys
OPENWEATHER_API_KEY=
GOOGLE_PLACES_API_KEY=
GSTIN_API_KEY=

# Twilio & WhatsApp Configuration
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WA_NUMBER=
WA_PROVIDER=twilio

# SSO / OIDC Provider (for Element X Single Sign-On via etke.cc Synapse)
# Generate a persistent private key once: node scripts/gen-oidc-key.js
# Then paste the output here. Without this, an ephemeral key is generated
# at startup and all Element X sessions will be lost on server restart.
OIDC_CLIENT_ID=nu-pmc
OIDC_CLIENT_SECRET=change-this-to-a-strong-secret
OIDC_PRIVATE_KEY=
OIDC_KEY_ID=nu-pmc-1
# Comma-separated allowed redirect URIs (Synapse's callback URL goes here)
# Example: https://matrix.nuassociates.in/_synapse/client/oidc/callback
OIDC_ALLOWED_REDIRECT_URIS=

# Payment Bank Settings
PAYMENT_BANK=icici
VENDOR_TOKEN_HOURS=
# ICICI payment webhook auth — REQUIRED in production. Requests without this
# secret are rejected (503). Get from your ICICI API dashboard.
ICICI_WEBHOOK_SECRET=
# AWS SES bounce/complaint webhook secret (if EMAIL_PROVIDER=ses is used later)
SES_WEBHOOK_SECRET=

# File upload limits
# Max upload size in MB (default: 25). Applied to express body parser + multer.
MAX_FILE_SIZE_MB=25

# Finance approval thresholds
# Petty cash approval ceiling in INR (default: 5000). Payments below this are
# auto-approved by coordinator; above require site manager sign-off.
PETTY_CASH_THRESHOLD=5000

# CSRF kill-switch — set to 'false' for emergency rollback only. Never disable in prod.
CSRF_ENABLED=true

# Twilio Templates
TWILIO_TMPL_DRAWING_ISSUED=
TWILIO_TMPL_QUERY_RAISED=
# TWILIO_TMPL_OTP — removed; self-service OTP reset was removed in v3.1 (April 2026)
TWILIO_TMPL_DAILY_REPORT=
TWILIO_TMPL_PAYMENT_CONFIRMED=
TWILIO_TMPL_DEFECT_RAISED=
TWILIO_TMPL_PI_RAISED=
TWILIO_TMPL_USER_CREATED=
